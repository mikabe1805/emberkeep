rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each anonymous user may touch exactly one document: their own save.
    match /saves/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Shared "spaces" (round-52, social): a public, read-only-to-others room
    // card keyed by a short share code. Only appearance data — never quests,
    // notes or email. Anyone signed in (everyone is, anonymously) may READ to
    // visit; you may only create/replace/delete a doc stamped with YOUR uid,
    // so no one can overwrite someone else's space.
    match /rooms/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
